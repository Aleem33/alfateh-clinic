{
  "name": "alfateh-healthcare-suite",
  "productName": "Al-Fateh Clinic",
  "private": true,
  "version": "3.1.47",
  "description": "Al-Fateh Clinic Integrated Hospital & Pharmacy Management Suite",
  "author": "Al-Fateh Clinic",
  "main": "main.js",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Aleem33/alfateh-clinic.git"
  },
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "electron:dev": "vite build --watch",
    "lint": "tsc --noEmit",
    "icons": "node scripts/generate-icons.mjs",
    "dist": "npm run build && electron-builder --win --publish never",
    "release": "npm run build && electron-builder --win --publish always",
    "bump:patch": "npm version patch --no-git-tag-version",
    "bump:minor": "npm version minor --no-git-tag-version",
    "bump:major": "npm version major --no-git-tag-version"
  },
  "build": {
    "appId": "com.alfateh.clinic",
    "productName": "Al-Fateh Clinic",
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "updater.js",
      "icon.ico",
      "icon.png",
      "build/icon.png",
      "assets/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Aleem33",
      "repo": "alfateh-clinic",
      "releaseType": "release"
    },
    "win": {
      "artifactName": "Al-Fateh-Clinic-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "artifactName": "Al-Fateh-Clinic-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Al-Fateh Clinic"
    },
    "directories": {
      "output": "release"
    },
    "icon": "assets/icon.png",
    "linux": {
      "icon": "assets/icon.png"
    },
    "mac": {
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^3.6.0",
    "electron-updater": "^6.8.3",
    "firebase": "^11.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.469.0",
    "papaparse": "^5.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-is": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.1",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^8.0.13"
  }
}
